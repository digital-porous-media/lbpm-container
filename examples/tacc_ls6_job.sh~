#!/bin/bash
#----------------------------------------------------
# LBPM Job Submission Script for TACC Lonestar6
#----------------------------------------------------
#SBATCH -J lbpm_job                    # Job name
#SBATCH -o lbpm_job.%j.out             # Output file
#SBATCH -e lbpm_job.%j.err             # Error file
#SBATCH -N 1                           # Number of nodes (single node only)
#SBATCH --ntasks-per-node 3            # Number of MPI ranks (= number of GPUs)
#SBATCH --gres=gpu:3                   # Number of GPUs
#SBATCH -p gpu-a100                    # Queue
#SBATCH -t 02:00:00                    # Wall time (hh:mm:ss)
#SBATCH -A your_allocation             # Allocation

#----------------------------------------------------
# Setup
#----------------------------------------------------
module load tacc-apptainer

# Path to your input file
INPUT_DB=$1
if [ -z "$INPUT_DB" ]; then
    echo "Usage: sbatch tacc_ls6_job.sh /path/to/input.db"
    exit 1
fi

# Number of GPUs (1, 2, or 3)
NUM_GPUS=${SLURM_NTASKS_PER_NODE:-1}

# Container image
IMAGE=lbpm_permeability.sif

# Pull container if not already present
if [ ! -f "$IMAGE" ]; then
    echo "Pulling container..."
    apptainer pull $IMAGE oras://docker.io/bchang19/lbpm:permeability-x86-cuda11-latest
fi

#----------------------------------------------------
# Run
#----------------------------------------------------
echo "Starting LBPM simulation..."
echo "Input: $INPUT_DB"
echo "GPUs: $NUM_GPUS"
echo "Container: $IMAGE"

apptainer run --nv $IMAGE $INPUT_DB $NUM_GPUS

echo "Simulation complete!"
