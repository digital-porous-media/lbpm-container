FROM nvidia/cuda:11.4.3-devel-ubuntu20.04

##################################
# Configure Environment
##################################
SHELL ["/bin/bash", "-c"]

ENV SHELL=/bin/bash
ENV DEBIAN_FRONTEND=noninteractive
RUN echo -e '#!/bin/bash\nexec "$@"' > /entry.sh && chmod +x /entry.sh
ENTRYPOINT ["/entry.sh"]

ENV TZ=US/Chicago
RUN apt-get update && apt-get upgrade -y && apt-get install -yq wget cmake git python3 \
python3-pip gfortran bison libibverbs-dev libnuma-dev \
libibmad-dev libibumad-dev librdmacm-dev libxml2-dev ca-certificates libfabric-dev
#RUN apt-get update && apt-get -y install gfortran fort77  \
#    build-essential curl libibverbs-dev  \
#    libibverbs1 libibcm1 librdmacm1 librdmacm-dev rdmacm-utils libibmad-dev libibmad5 \
#    byacc libibumad-dev libibumad3 infiniband-diags libmlx5-1 libmlx5-dev perftest ibverbs-utils opensm flex alien  \
#    && apt-get clean
ADD /pyLBPM /pyLBPM
WORKDIR /pyLBPM
RUN pip3 install . && chmod +rx /pyLBPM
ENV PATH "/pyLBPM:$PATH"
ENV PATH "$HOME/.local/bin:$PATH"

RUN python3 ./example/install_lbpm.py


